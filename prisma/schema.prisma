generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int            @id @default(autoincrement())
  name                String
  email               String         @unique
  password            String
  role                String         // Community Member, Worker, Facility Manager, Admin
  isActive            Boolean        @default(true)
  isVerified          Boolean        @default(false)
  actsOfServicePoints Int            @default(0)
  issues              Issue[]
  notifications       Notification[]
}

model Issue {
  id                 Int       @id @default(autoincrement())
  title              String    @db.VarChar(100)
  description        String    @db.Text
  status             String    @default("Submitted/Pending")
  priority           String    @default("Normal")
  category           String
  location           String    @db.VarChar(200)
  building           String    @default("") @db.VarChar(100)
  floor              String    @default("") @db.VarChar(50)
  room               String    @default("") @db.VarChar(50)

  image              String?
  completionPhotoUrl String?
  completionNote     String?
  rejectionReason    String?
  resolvedAt         DateTime?

  userId             Int
  assignedTo         Int?

  comments           Comment[]
  user               User      @relation(fields: [userId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  issueId   Int
  issue     Issue    @relation(fields: [issueId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  issueId   Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
